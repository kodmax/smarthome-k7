{
  "name": "@repo/cron-scripts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "imports": {
    "#config/*": "./dist/config/*.js"
  },
  "main": "./dist/knx/schedule.js",
  "types": "./dist/knx/schedule.d.ts",
  "exports": {
    ".": {
      "types": "./dist/knx/schedule.d.ts",
      "default": "./dist/knx/schedule.js"
    },
    "./knx/schedule": {
      "types": "./dist/knx/schedule.d.ts",
      "default": "./dist/knx/schedule.js"
    }
  },
  "dependencies": {
    "@repo/chronos": "*",
    "@repo/knx-schema": "*",
    "dotenv": "^17.4.2",
    "js-knx": "^2.20.1",
    "mariadb": "^3.0.0",
    "sony-bravia-ip-control": "^1.1.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^17.0.45",
    "typescript": "5.5.4"
  }
}
