{
  "name": "@repo/db",
  "private": true,
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "db:migrate": "node -r dotenv/config node_modules/.bin/db-migrate up",
    "db:rollback": "node -r dotenv/config node_modules/.bin/db-migrate down",
    "db:status": "node -r dotenv/config node_modules/.bin/db-migrate check",
    "db:create": "node -r dotenv/config node_modules/.bin/db-migrate create"
  },
  "dependencies": {
    "mariadb": "^3.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "dotenv": "^17.4.2",
    "typescript": "5.5.4"
  }
}
