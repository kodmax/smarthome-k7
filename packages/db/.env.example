# MariaDB credentials for schema migrations (db-migrate).
# Copy to .env — independent from apps/service/.env.
#
# Use a user with DDL privileges (CREATE/ALTER/DROP). Runtime pool credentials
# live in apps/service/.env as DB_HOST, DB_USER, DB_PASSWORD, DB_SCHEMA.

DB_MIGRATE_HOST=
DB_MIGRATE_USER=
DB_MIGRATE_PASSWORD=
DB_MIGRATE_SCHEMA=
