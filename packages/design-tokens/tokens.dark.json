{
  "color": {
    "background": "#1e2734",
    "surface": "#2a3340",
    "surfaceElevated": "#374352",
    "surfaceOverlay": "#3c4856",
    "border": "#363d47",
    "borderStrong": "#525a63",
    "textPrimary": "#d2d9e0",
    "textSecondary": "#9da5af",
    "textMuted": "#7d8590",
    "primary": "#3B82F6",
    "primaryLight": "#60A5FA",
    "primaryDark": "#1D4ED8",
    "success": "#22C55E",
    "warning": "#F59E0B",
    "danger": "#EF4444",
    "info": "#06B6D4",
    "purple": "#8B5CF6",
    "energy": "#22C55E",
    "temperature": "#F97316",
    "humidity": "#06B6D4",
    "air": "#10B981",
    "weather": "#06B6D4",
    "media": "#8B5CF6",
    "news": "#38BDF8",
    "jobs": "#60A5FA"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(0, 0, 0, 0.25)",
    "sm": "0 2px 4px rgba(0, 0, 0, 0.30)",
    "md": "0 4px 12px rgba(0, 0, 0, 0.45)",
    "lg": "0 8px 24px rgba(0, 0, 0, 0.55)",
    "xl": "0 16px 40px rgba(0, 0, 0, 0.65)",
    "card": "0 5px 14px rgba(0, 0, 0, 0.50)"
  },
  "card": {
    "radius": 16,
    "padding": 20,
    "gap": 12,
    "borderColor": "#434b55",
    "headerBorderColor": "#3d454f",
    "highlightTop": "rgba(255, 255, 255, 0.08)",
    "background": "{color.surface}",
    "shadow": "{shadow.card}"
  },
  "table": {
    "cellPadding": "0 4px 0 4px"
  }
}
