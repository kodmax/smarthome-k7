{
  "font": {
    "family": "Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "familyMono": "ui-monospace, SFMono-Regular, SF Mono, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace",
    "display1": { "size": 48, "weight": 700, "lineHeight": 1.1 },
    "display2": { "size": 36, "weight": 700, "lineHeight": 1.15 },
    "h1": { "size": 28, "weight": 600, "lineHeight": 1.2 },
    "h2": { "size": 22, "weight": 600, "lineHeight": 1.25 },
    "h3": { "size": 20, "weight": 700, "lineHeight": 1.3 },
    "metricLg": { "size": 32, "weight": 700, "lineHeight": 1 },
    "status": { "size": 18, "weight": 700, "lineHeight": 1.2 },
    "bodyLarge": { "size": 16, "weight": 400, "lineHeight": 1.6 },
    "body": { "size": 14, "weight": 400, "lineHeight": 1.6 },
    "bodySmall": { "size": 12, "weight": 400, "lineHeight": 1.6 },
    "caption": { "size": 11, "weight": 400, "lineHeight": 1.45 }
  },
  "space": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64,
    "20": 80,
    "24": 96
  },
  "radius": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "2xl": 24,
    "full": 9999
  },
  "borderWidth": {
    "hairline": 1,
    "regular": 1,
    "strong": 2
  },
  "layout": {
    "gridColumns": 12,
    "cardGridGap": 12,
    "gutter": 24,
    "containerMax": 1440,
    "bodyPadding": {
      "top": 8,
      "right": 32,
      "bottom": 32,
      "left": 32,
      "leftBelow2xl": 32
    },
    "paddingMobile": 24,
    "paddingTablet": 32,
    "paddingDesktop": 40
  },
  "transition": {
    "fast": "120ms ease-out",
    "normal": "200ms ease-out",
    "slow": "300ms ease-out"
  },
  "breakpoint": {
    "xs": 0,
    "sm": 576,
    "md": 768,
    "lg": 1034,
    "xl": 1280,
    "2xl": 1536
  },
  "icon": {
    "sizeXs": 14,
    "sizeSm": 22,
    "sizeAction": 16,
    "sizeMd": 24,
    "sizeLg": 48,
    "strokeWidth": 2,
    "style": "lucide"
  },
  "components": {
    "sectionLabel": {
      "letterSpacing": "0.08em",
      "fontWeight": 600,
      "marginBottom": 12
    },
    "pageHeader": {
      "iconSize": 36,
      "titleWeight": 700,
      "titleLineHeight": 1.2
    },
    "panel": {
      "padding": 24,
      "borderRadius": 16
    },
    "progressRing": {
      "size": 340,
      "strokeWidth": 14,
      "arcDegrees": 270,
      "timerLetterSpacing": "-0.02em",
      "controlsPaddingX": 48,
      "controlsPaddingTop": 16
    },
    "statIcon": {
      "size": 48,
      "glyphSize": 22
    },
    "statusDot": {
      "size": 10
    },
    "statsRow": {
      "gap": 64,
      "itemGap": 16,
      "bottomSpacing": 64
    },
    "sideMenu": {
      "drawerWidth": 272,
      "borderRadius": 20,
      "below2xlScale": 1.5,
      "logoSize": 40,
      "logoFontSize": 20,
      "navIconSize": 22,
      "toggleOpenSize": 24,
      "toggleClosedSize": 40,
      "toggleClosedOffset": 8,
      "toggleClosedZIndex": 100,
      "toggleOffsetY": 8,
      "toggleOpenOffsetY": 8,
      "toggleOpenOffsetX": 20,
      "toggleClosedBorderColor": "#D97706"
    }
  },
  "skillLevel": {
    "adept": "#C5C9D0",
    "regular": {
      "color": "#22C55E",
      "glow": "#4ADE80",
      "gradient": [
        { "offset": "0%", "color": "#ECFDF5" },
        { "offset": "30%", "color": "#86EFAC" },
        { "offset": "62%", "color": "#22C55E" },
        { "offset": "100%", "color": "#15803D" }
      ]
    },
    "master": {
      "color": "#FFD700",
      "glow": "#FFE566",
      "gradient": [
        { "offset": "0%", "color": "#FFFBE6" },
        { "offset": "30%", "color": "#FFE875" },
        { "offset": "62%", "color": "#FFD700" },
        { "offset": "100%", "color": "#E6A817" }
      ]
    },
    "knewBefore": {
      "color": "#94A3B8"
    }
  }
}
