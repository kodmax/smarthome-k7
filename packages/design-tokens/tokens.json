{
  "color": {
    "background": "#1e2734",
    "surface": "#2a3340",
    "surfaceElevated": "#374352",
    "surfaceOverlay": "#3c4856",
    "border": "#363d47",
    "borderStrong": "#525a63",
    "textPrimary": "#d2d9e0",
    "textSecondary": "#9da5af",
    "textMuted": "#7d8590",
    "primary": "#3B82F6",
    "primaryLight": "#60A5FA",
    "primaryDark": "#1D4ED8",
    "success": "#22C55E",
    "warning": "#F59E0B",
    "danger": "#EF4444",
    "info": "#06B6D4",
    "purple": "#8B5CF6",
    "energy": "#22C55E",
    "temperature": "#F97316",
    "humidity": "#06B6D4",
    "air": "#10B981",
    "weather": "#F59E0B",
    "media": "#8B5CF6",
    "news": "#38BDF8",
    "jobs": "#60A5FA"
  },
  "font": {
    "family": "Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "display1": { "size": 48, "weight": 700, "lineHeight": 1.1 },
    "display2": { "size": 36, "weight": 700, "lineHeight": 1.15 },
    "h1": { "size": 28, "weight": 600, "lineHeight": 1.2 },
    "h2": { "size": 22, "weight": 600, "lineHeight": 1.25 },
    "h3": { "size": 20, "weight": 700, "lineHeight": 1.3 },
    "bodyLarge": { "size": 16, "weight": 400, "lineHeight": 1.6 },
    "body": { "size": 14, "weight": 400, "lineHeight": 1.6 },
    "bodySmall": { "size": 12, "weight": 400, "lineHeight": 1.6 },
    "caption": { "size": 11, "weight": 400, "lineHeight": 1.45 }
  },
  "space": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64,
    "20": 80,
    "24": 96
  },
  "radius": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "2xl": 24,
    "full": 9999
  },
  "shadow": {
    "xs": "0 1px 2px rgba(0, 0, 0, 0.25)",
    "sm": "0 2px 4px rgba(0, 0, 0, 0.30)",
    "md": "0 4px 12px rgba(0, 0, 0, 0.45)",
    "lg": "0 8px 24px rgba(0, 0, 0, 0.55)",
    "xl": "0 16px 40px rgba(0, 0, 0, 0.65)",
    "card": "0 5px 14px rgba(0, 0, 0, 0.50)"
  },
  "borderWidth": {
    "hairline": 1,
    "regular": 1,
    "strong": 2
  },
  "layout": {
    "gridColumns": 12,
    "gutter": 24,
    "containerMax": 1920,
    "paddingMobile": 24,
    "paddingTablet": 32,
    "paddingDesktop": 40
  },
  "card": {
    "radius": 16,
    "padding": 20,
    "gap": 12,
    "borderColor": "#434b55",
    "headerBorderColor": "#3d454f",
    "highlightTop": "rgba(255, 255, 255, 0.08)",
    "background": "{color.surface}",
    "shadow": "{shadow.card}"
  },
  "table": {
    "cellPadding": "0 4px 0 4px"
  },
  "transition": {
    "fast": "120ms ease-out",
    "normal": "200ms ease-out",
    "slow": "300ms ease-out"
  },
  "breakpoint": {
    "xs": 0,
    "sm": 576,
    "md": 768,
    "lg": 1034,
    "xl": 1280,
    "2xl": 1536
  },
  "icon": {
    "sizeXs": 14,
    "sizeSm": 22,
    "sizeMd": 24,
    "sizeLg": 32,
    "strokeWidth": 2,
    "style": "lucide"
  }
}
