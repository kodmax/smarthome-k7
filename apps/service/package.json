{
  "name": "service",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "dependencies": {
    "@repo/apollo-ws": "*",
    "@repo/common": "*",
    "@repo/di": "*",
    "@repo/cron-scripts": "*",
    "@repo/db": "*",
    "@repo/knx-schema": "*",
    "@repo/transmission": "*",
    "@types/suncalc": "^1.8.1",
    "dotenv": "^17.4.2",
    "js-knx": "^3.1.0",
    "linkedom": "^0.18.12",
    "redis": "^6.1.0",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@repo/types": "*",
    "@types/node": "^17.0.36",
    "@typescript-eslint/eslint-plugin": "^5.47.0",
    "@typescript-eslint/parser": "^5.47.0",
    "bun": "^1.3.14",
    "eslint": "^8.30.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.6.0",
    "eslint-plugin-node": "11",
    "eslint-plugin-promise": "^6.1.1",
    "typescript": "^4.7.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "bundle": "bun build src/index.ts --target=node --format=cjs --outdir=./dist",
    "dev": "yarn bundle && sh -c 'bun build --watch src/index.ts --target=node --format=cjs --outdir=./dist & exec node --watch dist/index.js'",
    "dev:local": "sh -c 'yarn workspace @repo/chronos dev & yarn workspace @repo/apollo-ws dev & yarn workspace @repo/cron-scripts dev & yarn workspace @repo/db dev & yarn workspace @repo/di dev & yarn workspace @repo/knx-schema dev & yarn workspace @repo/transmission dev & exec yarn dev'",
    "start": "node dist/index.js",
    "build": "tsc && yarn bundle",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run"
  }
}
